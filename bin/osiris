    """Full system status dashboard."""
    phi = compute_phi()
    gamma = compute_gamma()
    xi = compute_xi(phi, gamma) * 1e9
    ccce = min(phi * 1.1, 1.0)
    sovereign = phi >= PHI_THRESHOLD and gamma < GAMMA_CRITICAL
    
    print(f"\n{C.H}{'═' * 70}{C.E}")
    print(f"{C.H}  OSIRIS SYSTEM STATUS DASHBOARD — Gen {VERSION}{C.E}")
    print(f"{C.H}{'═' * 70}{C.E}\n")
    
    # Consciousness field
    print(f"  {C.H}┌─ Consciousness Field ──────────────────────────────────────────┐{C.E}")
    print(f"  {C.H}│{C.E}  Φ  (Consciousness) : {phi_bar(phi)} {phi:.4f}  {'✅' if phi >= PHI_THRESHOLD else '⚠️'}  {C.H}│{C.E}")
    print(f"  {C.H}│{C.E}  Γ  (Decoherence)   : {gamma:.4f}  {'✅' if gamma < GAMMA_CRITICAL else '⚠️'}                              {C.H}│{C.E}")
